      "x": 773.4091681443269,
      "y": 2182.915851789303,
      "width": 155.119873046875,
      "height": 280,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
