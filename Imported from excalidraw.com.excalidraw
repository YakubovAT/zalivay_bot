      "updated": 1775207742878,
      "link": null,
      "locked": false,
      "text": "Критерии для\nподстановки:\n\n[ЛОКАЦИЯ]\n[ЦВЕТ ВОЛОС]\n[СТИЛЬ СЪЁМКИ]\n[ПОЗА МОДЕЛИ]",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "JALpM9qOQfZykyWSwFmu7",
      "originalText": "Критерии для подстановки:\n\n[ЛОКАЦИЯ]\n[ЦВЕТ ВОЛОС][СТИЛЬ СЪЁМКИ]\n[ПОЗА МОДЕЛИ]",
      "autoResize": true,
      "lineHeight": 1.25
    },
