    {
      "id": "uodcEWSM0eygBZ7sTuvKY",
      "type": "text",
      "x": -1883.4846972065511,
      "y": 2066.7057350256273,
      "width": 610.1275024414062,
      "height": 1600,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
