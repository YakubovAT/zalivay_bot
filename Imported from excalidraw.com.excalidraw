    {
      "id": "2bRAytqQp9XRT--ZThtF0",
      "type": "text",
      "x": 2170.0608939312046,
      "y": -202.8107605263848,
      "width": 612.78369140625,
      "height": 920,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2KV",
